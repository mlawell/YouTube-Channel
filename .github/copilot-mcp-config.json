{
  "mcpServers": {
    "context7": {
      "type": "sse",
      "tools": ["*"],
      "url": "https://mcp.context7.com/mcp"
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "tools": ["*"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${input:github_pat}"
      }
    },
    "azure": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@azure/mcp@latest", "server", "start"],
      "tools": ["*"]
    },
    "terraform": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "terraform-mcp-server"],
      "tools": ["*"]
    }
  },
  "inputs": [
    {
      "id": "github_pat",
      "type": "promptString",
      "description": "GitHub Personal Access Token (needs repo, read:org scopes)",
      "password": true
    }
  ]
}
